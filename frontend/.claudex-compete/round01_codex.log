+++ b/frontend/.claudex-compete/workspace_codex/src/components/research-dashboard/ResultsTable.tsx
@@ -0,0 +1,98 @@
+import type { SyntheticMarkerRow } from "./types";
+
+interface ResultsTableProps {
+  rows: SyntheticMarkerRow[];
+  isLoading: boolean;
+}
+
+const STATUS_STYLES: Record<SyntheticMarkerRow["status"], string> = {
+  Upregulated: "bg-emerald-100 text-emerald-700",
+  Downregulated: "bg-rose-100 text-rose-700",
+  Stable: "bg-slate-100 text-slate-700",
+};
+
+export function ResultsTable({ rows, isLoading }: ResultsTableProps) {
+  return (
+    <section className="panel-card p-5 sm:p-6">
+      <div className="flex flex-wrap items-end justify-between gap-3">
+        <div>
+          <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">
+            Marker outputs
+          </p>
+          <h3 className="font-display mt-1 text-xl font-semibold text-slate-900">
+            Synthetic assay table
+          </h3>
+        </div>
+        <p className="text-xs text-slate-500">
+          Values represent simulated endpoint payload fields.
+        </p>
+      </div>
+
+      <div className="mt-5 overflow-x-auto rounded-2xl border border-slate-200 bg-white">
+        <table className="min-w-full divide-y divide-slate-200 text-sm">
+          <caption className="sr-only">Synthetic marker results table</caption>
+          <thead className="bg-slate-50 text-left text-xs uppercase tracking-[0.1em] text-slate-600">
+            <tr>
+              <th className="px-4 py-3 font-semibold">Marker</th>
+              <th className="px-4 py-3 font-semibold">Pathway</th>
+              <th className="px-4 py-3 font-semibold">Baseline</th>
+              <th className="px-4 py-3 font-semibold">Treated</th>
+              <th className="px-4 py-3 font-semibold">Fold change</th>
+              <th className="px-4 py-3 font-semibold">Confidence</th>
+              <th className="px-4 py-3 font-semibold">Samples</th>
+              <th className="px-4 py-3 font-semibold">Status</th>
+            </tr>
+          </thead>
+          <tbody className="divide-y divide-slate-100">
+            {isLoading ? (
+              Array.from({ length: 6 }).map((_, index) => (
+                <tr key={`loading-row-${index}`} className="animate-pulse">
+                  {Array.from({ length: 8 }).map((__, cellIndex) => (
+                    <td key={`loading-cell-${cellIndex}`} className="px-4 py-3">
+                      <span className="block h-4 rounded bg-slate-200" />
+                    </td>
+                  ))}
+                </tr>
+              ))
+            ) : rows.length ? (
+              rows.map((row) => (
+                <tr key={row.id} className="hover:bg-slate-50/80">
+                  <td className="px-4 py-3 font-semibold text-slate-900">
+                    {row.marker}
+                  </td>
+                  <td className="px-4 py-3 text-slate-600">{row.pathway}</td>
+                  <td className="px-4 py-3 text-slate-700">{row.baseline}</td>
+                  <td className="px-4 py-3 text-slate-700">{row.treated}</td>
+                  <td className="px-4 py-3 font-semibold text-slate-900">
+                    {row.foldChange.toFixed(2)}x
+                  </td>
+                  <td className="px-4 py-3 text-slate-700">
+                    {row.confidence.toFixed(1)}%
+                  </td>
+                  <td className="px-4 py-3 text-slate-700">{row.sampleSize}</td>
+                  <td className="px-4 py-3">
+                    <span
+                      className={`rounded-full px-2.5 py-1 text-xs font-semibold ${STATUS_STYLES[row.status]}`}
+                    >
+                      {row.status}
+                    </span>
+                  </td>
+                </tr>
+              ))
+            ) : (
+              <tr>
+                <td
+                  colSpan={8}
+                  className="px-4 py-12 text-center text-sm text-slate-500"
+                >
+                  Upload a research paper and generate synthetic data to view
+                  table results.
+                </td>
+              </tr>
+            )}
+          </tbody>
+        </table>
+      </div>
+    </section>
+  );
+}
diff --git a/frontend/.claudex-compete/workspace_codex/src/components/research-dashboard/TrendChart.tsx b/frontend/.claudex-compete/workspace_codex/src/components/research-dashboard/TrendChart.tsx
new file mode 100644
index 0000000000000000000000000000000000000000..f5acd042e7852a35d49c8287acac500f95c2b9a9
--- /dev/null
+++ b/frontend/.claudex-compete/workspace_codex/src/components/research-dashboard/TrendChart.tsx
@@ -0,0 +1,178 @@
+import { TIME_POINTS, type SyntheticMarkerRow } from "./types";
+
+interface TrendChartProps {
+  rows: SyntheticMarkerRow[];
+  isLoading: boolean;
+}
+
+const CHART_WIDTH = 760;
+const CHART_HEIGHT = 270;
+
+const average = (values: number[]) => {
+  if (!values.length) {
+    return 0;
+  }
+
+  return values.reduce((total, value) => total + value, 0) / values.length;
+};
+
+const toPointString = (series: number[], minY: number, maxY: number) => {
+  const delta = Math.max(1, maxY - minY);
+
+  return series
+    .map((value, index) => {
+      const x = (index / Math.max(1, series.length - 1)) * CHART_WIDTH;
+      const y = CHART_HEIGHT - ((value - minY) / delta) * CHART_HEIGHT;
+      return `${x},${y}`;
+    })
+    .join(" ");
+};
+
+export function TrendChart({ rows, isLoading }: TrendChartProps) {
+  const hasData = rows.length > 0;
+
+  const controlSeries = TIME_POINTS.map((_, pointIndex) =>
+    average(rows.map((row) => row.controlSeries[pointIndex])),
+  );
+
+  const treatedSeries = TIME_POINTS.map((_, pointIndex) =>
+    average(rows.map((row) => row.treatedSeries[pointIndex])),
+  );
+
+  const chartValues = [...controlSeries, ...treatedSeries];
+  const minY = hasData ? Math.min(...chartValues) - 4 : 0;
+  const maxY = hasData ? Math.max(...chartValues) + 4 : 100;
+
+  return (
+    <section className="panel-card p-5 sm:p-6">
+      <div className="flex flex-wrap items-start justify-between gap-4">
+        <div>
+          <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">
+            Synthetic trajectory
+          </p>
+          <h3 className="font-display mt-1 text-xl font-semibold text-slate-900">
+            Mean expression trend over time
+          </h3>
+        </div>
+        <div className="flex items-center gap-4 text-xs font-medium">
+          <div className="flex items-center gap-2 text-slate-600">
+            <span className="h-2.5 w-2.5 rounded-full bg-sky-500" />
+            Control
+          </div>
+          <div className="flex items-center gap-2 text-slate-600">
+            <span className="h-2.5 w-2.5 rounded-full bg-emerald-500" />
+            Treated
+          </div>
+        </div>
+      </div>
+
+      <div className="mt-5 overflow-x-auto">
+        <div className="min-w-[700px]">
+          {isLoading ? (
+            <div className="h-[320px] animate-pulse rounded-2xl border border-slate-200 bg-slate-100" />
+          ) : hasData ? (
+            <>
+              <svg viewBox={`0 0 ${CHART_WIDTH} ${CHART_HEIGHT + 55}`}>
+                <defs>
+                  <linearGradient id="treatedGradient" x1="0" y1="0" x2="0" y2="1">
+                    <stop offset="0%" stopColor="#10b981" stopOpacity="0.25" />
+                    <stop
+                      offset="100%"
+                      stopColor="#10b981"
+                      stopOpacity="0.01"
+                    />
+                  </linearGradient>
+                </defs>
+
+                {Array.from({ length: 5 }).map((_, index) => {
+                  const y = (index / 4) * CHART_HEIGHT;
+                  return (
+                    <line
+                      key={`grid-${index}`}
+                      x1={0}
+                      y1={y}
+                      x2={CHART_WIDTH}
+                      y2={y}
+                      stroke="rgb(148 163 184 / 0.28)"
+                      strokeWidth={1}
+                    />
+                  );
+                })}
+
+                <polyline
+                  points={`${toPointString(
+                    treatedSeries,
+                    minY,
+                    maxY,
+                  )} ${CHART_WIDTH},${CHART_HEIGHT} 0,${CHART_HEIGHT}`}
+                  fill="url(#treatedGradient)"
+                  stroke="none"
+                />
+
+                <polyline
+                  points={toPointString(controlSeries, minY, maxY)}
+                  fill="none"
+                  stroke="#0ea5e9"
+                  strokeWidth={3}
+                  strokeLinecap="round"
+                  strokeLinejoin="round"
+                />
+                <polyline
+                  points={toPointString(treatedSeries, minY, maxY)}
+                  fill="none"
+                  stroke="#10b981"
+                  strokeWidth={3}
+                  strokeLinecap="round"
+                  strokeLinejoin="round"
+                />
+
+                {treatedSeries.map((value, index) => {
+                  const x = (index / Math.max(1, treatedSeries.length - 1)) * CHART_WIDTH;
+                  const y =
+                    CHART_HEIGHT -
+                    ((value - minY) / Math.max(1, maxY - minY)) * CHART_HEIGHT;
+
+                  return (
+                    <circle
+                      key={`treated-point-${TIME_POINTS[index]}`}
+                      cx={x}
+                      cy={y}
+                      r={4}
+                      fill="#10b981"
+                      stroke="white"
+                      strokeWidth={2}
+                    />
+                  );
+                })}
+
+                {TIME_POINTS.map((timePoint, index) => {
+                  const x = (index / Math.max(1, TIME_POINTS.length - 1)) * CHART_WIDTH;
+                  return (
+                    <text
+                      key={timePoint}
+                      x={x}
+                      y={CHART_HEIGHT + 32}
+                      textAnchor="middle"
+                      fontSize="12"
+                      fill="#475569"
+                    >
+                      {timePoint}
+                    </text>
+                  );
+                })}
+              </svg>
+              <p className="mt-2 text-xs text-slate-500">
+                Treated samples are compared to control means across six
+                synthesis intervals.
+              </p>
+            </>
+          ) : (
+            <div className="flex h-[320px] items-center justify-center rounded-2xl border border-slate-200 bg-white text-sm text-slate-500">
+              Run a paper analysis to populate chart data.
+            </div>
+          )}
+        </div>
+      </div>
+    </section>
+  );
+}
