@@ -0,0 +1,178 @@
+import { TIME_POINTS, type SyntheticMarkerRow } from "./types";
+
+interface TrendChartProps {
+  rows: SyntheticMarkerRow[];
+  isLoading: boolean;
+}
+
+const CHART_WIDTH = 760;
+const CHART_HEIGHT = 270;
+
+const average = (values: number[]) => {
+  if (!values.length) {
+    return 0;
+  }
+
+  return values.reduce((total, value) => total + value, 0) / values.length;
+};
+
+const toPointString = (series: number[], minY: number, maxY: number) => {
+  const delta = Math.max(1, maxY - minY);
+
+  return series
+    .map((value, index) => {
+      const x = (index / Math.max(1, series.length - 1)) * CHART_WIDTH;
+      const y = CHART_HEIGHT - ((value - minY) / delta) * CHART_HEIGHT;
+      return `${x},${y}`;
+    })
+    .join(" ");
+};
+
+export function TrendChart({ rows, isLoading }: TrendChartProps) {
+  const hasData = rows.length > 0;
+
+  const controlSeries = TIME_POINTS.map((_, pointIndex) =>
+    average(rows.map((row) => row.controlSeries[pointIndex])),
+  );
+
+  const treatedSeries = TIME_POINTS.map((_, pointIndex) =>
+    average(rows.map((row) => row.treatedSeries[pointIndex])),
+  );
+
+  const chartValues = [...controlSeries, ...treatedSeries];
+  const minY = hasData ? Math.min(...chartValues) - 4 : 0;
+  const maxY = hasData ? Math.max(...chartValues) + 4 : 100;
+
+  return (
+    <section className="panel-card p-5 sm:p-6">
+      <div className="flex flex-wrap items-start justify-between gap-4">
+        <div>
+          <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">
+            Synthetic trajectory
+          </p>
+          <h3 className="font-display mt-1 text-xl font-semibold text-slate-900">
+            Mean expression trend over time
+          </h3>
+        </div>
+        <div className="flex items-center gap-4 text-xs font-medium">
+          <div className="flex items-center gap-2 text-slate-600">
+            <span className="h-2.5 w-2.5 rounded-full bg-sky-500" />
+            Control
+          </div>
+          <div className="flex items-center gap-2 text-slate-600">
+            <span className="h-2.5 w-2.5 rounded-full bg-emerald-500" />
+            Treated
+          </div>
+        </div>
+      </div>
+
+      <div className="mt-5 overflow-x-auto">
+        <div className="min-w-[700px]">
+          {isLoading ? (
+            <div className="h-[320px] animate-pulse rounded-2xl border border-slate-200 bg-slate-100" />
+          ) : hasData ? (
+            <>
+              <svg viewBox={`0 0 ${CHART_WIDTH} ${CHART_HEIGHT + 55}`}>
+                <defs>
+                  <linearGradient id="treatedGradient" x1="0" y1="0" x2="0" y2="1">
+                    <stop offset="0%" stopColor="#10b981" stopOpacity="0.25" />
+                    <stop
+                      offset="100%"
+                      stopColor="#10b981"
+                      stopOpacity="0.01"
+                    />
+                  </linearGradient>
+                </defs>
+
+                {Array.from({ length: 5 }).map((_, index) => {
+                  const y = (index / 4) * CHART_HEIGHT;
+                  return (
+                    <line
+                      key={`grid-${index}`}
+                      x1={0}
+                      y1={y}
+                      x2={CHART_WIDTH}
+                      y2={y}
+                      stroke="rgb(148 163 184 / 0.28)"
+                      strokeWidth={1}
+                    />
+                  );
+                })}
+
+                <polyline
+                  points={`${toPointString(
+                    treatedSeries,
+                    minY,
+                    maxY,
+                  )} ${CHART_WIDTH},${CHART_HEIGHT} 0,${CHART_HEIGHT}`}
+                  fill="url(#treatedGradient)"
+                  stroke="none"
+                />
+
+                <polyline
+                  points={toPointString(controlSeries, minY, maxY)}
+                  fill="none"
+                  stroke="#0ea5e9"
+                  strokeWidth={3}
+                  strokeLinecap="round"
+                  strokeLinejoin="round"
+                />
+                <polyline
+                  points={toPointString(treatedSeries, minY, maxY)}
+                  fill="none"
+                  stroke="#10b981"
+                  strokeWidth={3}
+                  strokeLinecap="round"
+                  strokeLinejoin="round"
+                />
+
+                {treatedSeries.map((value, index) => {
+                  const x = (index / Math.max(1, treatedSeries.length - 1)) * CHART_WIDTH;
+                  const y =
+                    CHART_HEIGHT -
+                    ((value - minY) / Math.max(1, maxY - minY)) * CHART_HEIGHT;
+
+                  return (
+                    <circle
+                      key={`treated-point-${TIME_POINTS[index]}`}
+                      cx={x}
+                      cy={y}
+                      r={4}
+                      fill="#10b981"
+                      stroke="white"
+                      strokeWidth={2}
+                    />
+                  );
+                })}
+
+                {TIME_POINTS.map((timePoint, index) => {
+                  const x = (index / Math.max(1, TIME_POINTS.length - 1)) * CHART_WIDTH;
+                  return (
+                    <text
+                      key={timePoint}
+                      x={x}
+                      y={CHART_HEIGHT + 32}
+                      textAnchor="middle"
+                      fontSize="12"
+                      fill="#475569"
+                    >
+                      {timePoint}
+                    </text>
+                  );
+                })}
+              </svg>
+              <p className="mt-2 text-xs text-slate-500">
+                Treated samples are compared to control means across six
+                synthesis intervals.
+              </p>
+            </>
+          ) : (
+            <div className="flex h-[320px] items-center justify-center rounded-2xl border border-slate-200 bg-white text-sm text-slate-500">
+              Run a paper analysis to populate chart data.
+            </div>
+          )}
+        </div>
+      </div>
+    </section>
+  );
+}
