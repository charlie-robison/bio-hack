+
+export interface SyntheticMarkerRow {
+  id: string;
+  marker: string;
+  pathway: string;
+  baseline: number;
+  treated: number;
+  foldChange: number;
+  confidence: number;
+  sampleSize: number;
+  status: MarkerStatus;
+  controlSeries: number[];
+  treatedSeries: number[];
+}
+
+export interface SyntheticDataset {
+  paperTitle: string;
+  generatedAt: string;
+  pipelineVersion: string;
+  rows: SyntheticMarkerRow[];
+}

