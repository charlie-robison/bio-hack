+++ b/frontend/.claudex-compete/workspace_codex/src/components/research-dashboard/ResearchDashboard.tsx
@@ -0,0 +1,135 @@
+"use client";
+
+import { useMemo, useState } from "react";
+import { createSyntheticDataset } from "./data";
+import { MetricsCards } from "./MetricsCards";
+import { ResultsTable } from "./ResultsTable";
+import { TrendChart } from "./TrendChart";
+import type { SyntheticDataset } from "./types";
+import { UploadPanel } from "./UploadPanel";
+
+const formatPaperName = (name: string) =>
+  name.replace(/\.[^/.]+$/, "").replace(/[_-]+/g, " ").trim();
+
+export function ResearchDashboard() {
+  const [selectedFile, setSelectedFile] = useState<File | null>(null);
+  const [dataset, setDataset] = useState<SyntheticDataset | null>(null);
+  const [isLoading, setIsLoading] = useState(false);
+  const [lastRunAt, setLastRunAt] = useState<Date | null>(null);
+  const [error, setError] = useState<string | null>(null);
+
+  const lastRunLabel = useMemo(() => {
+    if (!lastRunAt) {
+      return "No runs yet";
+    }
+
+    return new Intl.DateTimeFormat("en-US", {
+      month: "short",
+      day: "numeric",
+      hour: "numeric",
+      minute: "2-digit",
+    }).format(lastRunAt);
+  }, [lastRunAt]);
+
+  const onAnalyze = async () => {
+    if (!selectedFile) {
+      setError("Select a paper before running analysis.");
+      return;
+    }
+
+    setError(null);
+    setIsLoading(true);
+
+    try {
+      // Replace this timer with an API request once the endpoint is ready.
+      await new Promise((resolve) => setTimeout(resolve, 1650));
+
+      const generated = createSyntheticDataset(
+        formatPaperName(selectedFile.name),
+      );
+      setDataset(generated);
+      setLastRunAt(new Date(generated.generatedAt));
+    } catch {
+      setError("Unable to generate synthetic output. Try again.");
+    } finally {
+      setIsLoading(false);
+    }
+  };
+
+  return (
+    <main className="min-h-screen pb-10">
+      <div className="mx-auto max-w-7xl px-4 py-8 sm:px-6 lg:px-8">
+        <header className="mb-8 flex flex-wrap items-end justify-between gap-6">
+          <div>
+            <p className="text-xs font-semibold uppercase tracking-[0.22em] text-teal-700">
+              BioSynth Workspace
+            </p>
+            <h1 className="font-display mt-2 text-3xl font-semibold text-slate-900 sm:text-4xl">
+              Paper-to-Data Dashboard
+            </h1>
+            <p className="mt-3 max-w-3xl text-sm text-slate-600 sm:text-base">
+              Upload a scientific biology paper, simulate endpoint processing,
+              and review generated synthetic markers in a table and trend graph.
+            </p>
+          </div>
+
+          <div className="panel-card flex min-w-[220px] items-center gap-3 px-4 py-3">
+            <div
+              className={`h-3 w-3 rounded-full ${
+                isLoading ? "animate-pulse bg-amber-500" : "bg-emerald-500"
+              }`}
+            />
+            <div>
+              <p className="text-xs font-medium uppercase tracking-[0.13em] text-slate-500">
+                System state
+              </p>
+              <p className="text-sm font-semibold text-slate-800">
+                {isLoading ? "Synthesizing dataset..." : "Ready for upload"}
+              </p>
+            </div>
+          </div>
+        </header>
+
+        <section className="grid gap-6 xl:grid-cols-[360px_minmax(0,1fr)]">
+          <UploadPanel
+            selectedFile={selectedFile}
+            isLoading={isLoading}
+            hasResults={Boolean(dataset)}
+            error={error}
+            lastRunLabel={lastRunLabel}
+            onFileSelect={(file) => {
+              setSelectedFile(file);
+              setError(null);
+            }}
+            onAnalyze={onAnalyze}
+          />
+
+          <div className="space-y-6">
+            <MetricsCards dataset={dataset} isLoading={isLoading} />
+
+            <section className="panel-card p-4 sm:p-5">
+              <div className="flex flex-wrap items-start justify-between gap-4">
+                <div>
+                  <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500">
+                    Active dataset
+                  </p>
+                  <p className="font-display mt-1 text-lg font-semibold text-slate-900">
+                    {dataset?.paperTitle ?? "No paper loaded"}
+                  </p>
+                </div>
+                <div className="rounded-xl bg-slate-100 px-3 py-2 text-xs text-slate-600">
+                  {dataset
+                    ? `Pipeline ${dataset.pipelineVersion}`
+                    : "Waiting for first run"}
+                </div>
+              </div>
+            </section>
+
+            <TrendChart rows={dataset?.rows ?? []} isLoading={isLoading} />
+            <ResultsTable rows={dataset?.rows ?? []} isLoading={isLoading} />
+          </div>
+        </section>
+      </div>
+    </main>
+  );
+}
