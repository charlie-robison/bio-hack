                <p className="text-sm font-semibold text-slate-800">
                  {isLoading ? "Synthesizing dataset..." : "Ready for upload"}
                </p>
              </div>
            </div>
            <div className="mt-5 grid grid-cols-2 gap-3 text-sm">
              <div className="rounded-xl bg-slate-100 p-3">
